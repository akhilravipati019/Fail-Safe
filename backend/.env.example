# Copy this file to .env and fill in real values.

# Used to sign JWT access tokens. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret

# JWT access token lifetime, in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite database file (relative to backend/)
DATABASE_URL=sqlite:///./failsafe.db

# Origin(s) of the frontend, used for CORS. Comma-separate multiple origins,
# e.g. http://localhost:5173,https://failsafe-frontend.onrender.com
FRONTEND_ORIGIN=http://localhost:5173

# Optional: enables AI-generated narrative explanations via Gemini.
# If left blank, the app falls back to rule-based suggestions only.
GEMINI_API_KEY=

# Login lockout settings
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
